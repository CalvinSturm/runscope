{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RunScope",
  "version": "0.1.0",
  "identifier": "dev.calvin.runscope",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../../../ui",
    "beforeBuildCommand": "npm run build --prefix ../../../ui",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../../../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "RunScope",
        "width": 1480,
        "height": 920,
        "minWidth": 1120,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
